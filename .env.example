# Discord Bot (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token
GUILD_ID=your_server_id

# Publer (Business/Enterprise plan - from https://app.publer.com)
# API Key: Settings → Access & Login → API Keys (scopes: workspaces, accounts, posts, media)
# Uses workspace named "emil" and all its active accounts (Twitter, Threads, etc.)
PUBLER_API_KEY=your_publer_api_key

# Optional: use a different workspace name (default is "emil")
# PUBLER_WORKSPACE_NAME=my_workspace

# Optional: exclude providers that block drafts (e.g. Twitter duplicate-content policy)
# PUBLER_EXCLUDE_PROVIDERS=twitter

# Optional: create ideas as private (default is public/workspace-visible)
# PUBLER_IDEA_PRIVATE=true

# Optional: timezone for Schedule to all (default: server/UTC). Use abbreviations: CET, EST, PST, etc.
# PUBLER_SCHEDULE_TIMEZONE=CET
